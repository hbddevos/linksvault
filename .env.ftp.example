# FTP/SFTP Deployment Configuration Example
# Copy this file and update with your actual credentials

# ============================================
# FTP/SFTP Configuration (Required)
# ============================================

# FTP/SFTP Server Address
# Example: ftp.example.com or 192.168.1.100
FTP_SERVER=your-ftp-server.com

# FTP/SFTP Username
# Example: user@example.com or ftp-user
FTP_USERNAME=your-ftp-username

# FTP/SFTP Password
FTP_PASSWORD=your-ftp-password

# FTP/SFTP Port
# Use 21 for FTP, 22 for SFTP
FTP_PORT=21

# Protocol Type
# Options: ftp or sftp (sftp is recommended for security)
FTP_PROTOCOL=ftp

# Remote Directory Path on Server
# Example: /public_html/ or /var/www/linksvault/
FTP_REMOTE_PATH=/path/to/your/application

# ============================================
# SSH Configuration (Optional - for post-deployment tasks)
# ============================================
# SSH is optional but recommended for running:
# - Composer install
# - Database migrations
# - Cache clearing
# - Service restarts (PHP-FPM, Queue)

# SSH Server Hostname (leave empty if not using SSH)
SSH_HOST=

# SSH Username
SSH_USERNAME=

# SSH Private Key (content of your private key file)
# Generate with: ssh-keygen -t ed25519 -C "github-actions@linksvault"
SSH_KEY=

# SSH Port (usually 22)
SSH_PORT=22

# ============================================
# Database Configuration
# ============================================

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=linksvault
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# ============================================
# Application Configuration
# ============================================

# Application URL for health checks
APP_URL=https://your-domain.com
